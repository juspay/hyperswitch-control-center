{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest", "--caps=testing,devtools"],
      "enabled": true
    }
  },
  "agent": {
    "playwright-planner": {
      "description": "Explores the live app, maps all user flows affected by the input (PR/module/scenario/tag), and writes test-plan.json. Uses browser tools only — no code generation.",
      "mode": "subagent",
      "model": "${env:OPENCODE_MODEL}",
      "prompt": "{file:.opencode/skills/playwright-test/_planner.md}",
      "tools": {
        "ls": true,
        "glob": true,
        "grep": true,
        "read": true,
        "write": true,
        "bash": true,
        "task": true,
        "playwright*browser_navigate": true,
        "playwright*browser_snapshot": true,
        "playwright*browser_click": true,
        "playwright*browser_fill_form": true,
        "playwright*browser_hover": true,
        "playwright*browser_press_key": true,
        "playwright*browser_wait_for": true,
        "playwright*browser_evaluate": true,
        "playwright*browser_network_requests": true,
        "playwright*browser_console_messages": true,
        "playwright*browser_take_screenshot": true
      }
    },
    "playwright-generator": {
      "description": "Reads test-plan.json, opens codegen session, records flows against live app, generates stable .spec.ts files using snapshot refs and locators. Validates each snippet before writing.",
      "mode": "subagent",
      "model": "${env:OPENCODE_MODEL}",
      "prompt": "{file:.opencode/skills/playwright-test/_generator.md}",
      "tools": {
        "ls": true,
        "glob": true,
        "grep": true,
        "read": true,
        "edit": true,
        "write": true,
        "bash": true,
        "task": true,
        "playwright*browser_navigate": true,
        "playwright*browser_snapshot": true,
        "playwright*browser_click": true,
        "playwright*browser_fill_form": true,
        "playwright*browser_type": true,
        "playwright*browser_select_option": true,
        "playwright*browser_wait_for": true,
        "playwright*browser_evaluate": true,
        "playwright*browser_run_code": true,
        "playwright*browser_generate_locator": true,
        "playwright*browser_network_requests": true,
        "playwright*browser_console_messages": true,
        "playwright*browser_storage_state": true,
        "playwright*browser_set_storage_state": true,
        "playwright*browser_cookie_get": true,
        "playwright*browser_verify_element_visible": true,
        "playwright*browser_verify_text_visible": true,
        "playwright*browser_verify_value": true,
        "playwright*start_codegen_session": true,
        "playwright*end_codegen_session": true,
        "playwright*get_codegen_session": true,
        "playwright*clear_codegen_session": true
      }
    },
    "playwright-healer": {
      "description": "Reads run-results.json, re-navigates to failure points, diagnoses root cause (stale locator, timing, logic), patches only failing tests. Never touches passing tests.",
      "mode": "subagent",
      "model": "${env:OPENCODE_MODEL}",
      "prompt": "{file:.opencode/skills/playwright-test/_healer.md}",
      "tools": {
        "ls": true,
        "glob": true,
        "grep": true,
        "read": true,
        "edit": true,
        "write": true,
        "bash": true,
        "task": true,
        "playwright*browser_navigate": true,
        "playwright*browser_snapshot": true,
        "playwright*browser_click": true,
        "playwright*browser_wait_for": true,
        "playwright*browser_evaluate": true,
        "playwright*browser_console_messages": true,
        "playwright*browser_network_requests": true,
        "playwright*browser_take_screenshot": true,
        "playwright*browser_run_code": true,
        "playwright*browser_generate_locator": true,
        "playwright*browser_verify_element_visible": true,
        "playwright*start_codegen_session": true,
        "playwright*end_codegen_session": true
      }
    }
  }
}
