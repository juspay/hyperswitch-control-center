{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright-test": {
      "type": "local",
      "command": ["npx", "playwright", "run-test-mcp-server"],
      "enabled": true
    }
  },
  "tools": {
    "playwright*": true
  },
  "agent": {
    "playwright-test-orchestrator": {
      "description": "Central dispatcher for Playwright test automation. Receives ALL user requests from SKILL.md, detects execution mode (full/plan/generate/heal), and orchestrates the appropriate workflow. Handles setup, task execution, summary, bug reports, and cleanup consistently across all modes.",
      "mode": "subagent",
      "model": "${env:OPENCODE_MODEL}",
      "prompt": "{file:.opencode/skills/playwright-test/orchestrator.md}",
      "tools": {
        "ls": true,
        "glob": true,
        "grep": true,
        "read": true,
        "edit": true,
        "write": true,
        "bash": true,
        "skill": true,
        "task": true,
        "playwright-test*browser_navigate": true,
        "playwright-test*browser_click": true,
        "playwright-test*browser_evaluate": true,
        "playwright-test*browser_snapshot": true,
        "playwright-test*browser_wait_for": true,
        "playwright-test*browser_console_messages": true,
        "playwright-test*browser_generate_locator": true,
        "playwright-test*browser_network_requests": true
      }
    },
    "playwright-planner": {
      "description": "Test planner agent for Playwright. Called by orchestrator during Step 3 to create comprehensive test plans from PR/module/scenario analysis. Writes test-plan.json for use by generator agent.",
      "mode": "subagent",
      "model": "${env:OPENCODE_MODEL}",
      "prompt": "{file:.opencode/skills/playwright-test/_planner.md}",
      "tools": {
        "ls": true,
        "glob": true,
        "grep": true,
        "read": true,
        "edit": true,
        "write": true,
        "bash": true,
        "skill": true,
        "task": true,
        "playwright-test*browser_navigate": true,
        "playwright-test*browser_click": true,
        "playwright-test*browser_evaluate": true,
        "playwright-test*browser_snapshot": true,
        "playwright-test*browser_wait_for": true,
        "playwright-test*browser_console_messages": true,
        "playwright-test*browser_generate_locator": true,
        "playwright-test*browser_network_requests": true
      }
    },
    "playwright-generator": {
      "description": "Test generator agent for Playwright. Called by orchestrator during Step 4 to generate executable test code from test plans. Writes *.spec.ts files to playwright-tests/ai-generated/.",
      "mode": "subagent",
      "model": "${env:OPENCODE_MODEL}",
      "prompt": "{file:.opencode/skills/playwright-test/_generator.md}",
      "tools": {
        "ls": true,
        "glob": true,
        "grep": true,
        "read": true,
        "edit": true,
        "write": true,
        "bash": true,
        "skill": true,
        "task": true,
        "playwright-test*browser_navigate": true,
        "playwright-test*browser_click": true,
        "playwright-test*browser_evaluate": true,
        "playwright-test*browser_snapshot": true,
        "playwright-test*browser_wait_for": true,
        "playwright-test*browser_console_messages": true,
        "playwright-test*browser_generate_locator": true,
        "playwright-test*browser_network_requests": true,
        "playwright-test*generator_read_log": true,
        "playwright-test*generator_setup_page": true,
        "playwright-test*generator_write_test": true
      }
    },
    "playwright-healer": {
      "description": "Test healer agent for Playwright. Called by orchestrator during Step 6 to debug and fix failing tests. Reads run-results.json, diagnoses issues, and updates test files.",
      "mode": "subagent",
      "model": "${env:OPENCODE_MODEL}",
      "prompt": "{file:.opencode/skills/playwright-test/_healer.md}",
      "tools": {
        "ls": true,
        "glob": true,
        "grep": true,
        "read": true,
        "edit": true,
        "write": true,
        "bash": true,
        "skill": true,
        "task": true,
        "playwright-test*browser_navigate": true,
        "playwright-test*browser_click": true,
        "playwright-test*browser_evaluate": true,
        "playwright-test*browser_snapshot": true,
        "playwright-test*browser_wait_for": true,
        "playwright-test*browser_console_messages": true,
        "playwright-test*browser_generate_locator": true,
        "playwright-test*browser_network_requests": true
      }
    }
  }
}
